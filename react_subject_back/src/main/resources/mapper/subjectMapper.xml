<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="kr.co.iei.subject.model.dao.SubjectDao">
	<select id="searchSubjectList" resultType="subject">
		select * from subject_tbl 
				<where>
            		<if test="keyword != null and keyword != ''">
                		and subject_title like '%' || upper(#{keyword}) || '%'
            		</if>

            		<if test="category != 0">
                		and subject_category = #{category}
            		</if>

            		<if test="level != 0">
                		and subject_level = #{level}
            		</if>
        		</where>
            		<if test="order == 1">
            			order by subject_no desc
            		</if>
            		<if test="order == 2">
            			order by subject_level desc, subject_title asc
            		</if>
            		<if test="order == 3">
            			order by subject_level asc, subject_title asc
            		</if>
            		<if test="order == 4">
            			order by subject_count desc, subject_title asc
            		</if>
            		<if test="order == 5">
            			order by subject_count asc, subject_title asc
            		</if>
	</select>
</mapper>
